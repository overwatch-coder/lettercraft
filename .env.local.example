# Copy to .env.local and fill in values.

# Used server-side for AES-GCM decryption of the stored API key.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_SECRET=change-this-to-a-random-32-byte-hex-string

# Optional server-side default key — users won't need to enter their own.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AI...
